DATABASE_URL=postgresql://dr_stone:dr_stone@127.0.0.1:15432/dr_stone_test
TIMEOUT_SECONDS=15
MAX_RETRIES=2
RETRY_BACKOFF_SECONDS=1.0
REQUEST_DELAY_SECONDS=0.5
# Proxy is currently disabled. Set all three variables to re-enable it for
# browser-backed sources (amazon, pichau, mercadolivre). Empty / unset values
# disable the proxy entirely; source code already short-circuits when empty.
# PROXY_SERVER=http://127.0.0.1:3128
# PROXY_USER=proxyuser
# PROXY_PASSWORD=change-me
# Comma-separated list of sources that route directly even when the global
# proxy is configured. Sources without proxy support ignore this. Default
# (when unset): all known sources are disabled. Set to an empty string to
# route every source through the proxy, or list specific sources.
# DR_STONE_PROXY_DISABLED_SOURCES=mercadolivre
LOG_LEVEL=info
USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/134.0.0.0 Safari/537.36
INTERVAL_SECONDS=21600
DR_STONE_ENABLED_SOURCES=kabum,amazon
TEST_DATABASE_URL=postgresql://dr_stone:dr_stone@127.0.0.1:15432/dr_stone_test
