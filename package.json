{
  "name": "dr-stone",
  "private": true,
  "packageManager": "pnpm@10.7.1",
  "scripts": {
    "build": "corepack pnpm exec tsc -b",
    "lint": "corepack pnpm --recursive --filter @dr-stone/api --filter @dr-stone/database --filter @dr-stone/scrapper run lint",
    "typecheck": "corepack pnpm exec tsc -b --pretty false --force",
    "test": "vitest run",
    "migrate": "corepack pnpm --filter @dr-stone/database run migrate",
    "start:api": "node dr-stone-api/dist/index.js",
    "start:worker": "node dr-stone-scrapper/dist/worker.js",
    "worker:once": "node dr-stone-scrapper/dist/worker.js --run-once",
    "source:run": "node dr-stone-scrapper/dist/scripts/run-source.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@types/node": "^24.5.2",
    "@types/pg": "^8.15.1",
    "eslint": "^9.23.0",
    "globals": "^16.0.0",
    "pg": "^8.14.1",
    "turbo": "^2.8.17",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.28.0",
    "vitest": "^3.0.9"
  }
}
